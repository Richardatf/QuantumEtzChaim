{
  "name": "quantum-etz-chaim",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/verify-published-links.mjs",
    "format:check": "prettier --check .",
    "test": "vitest run tests",
    "golden:check": "vitest run tests/golden-traces.test.ts",
    "golden:update": "cross-env UPDATE_GOLDENS=1 vitest run tests/golden-traces.test.ts",
    "production:check": "node scripts/check-production-coherence.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ivritcode/core": "https://github.com/Richardatf/IvritCode/releases/download/canonical-packages-2026.07.20.1/ivritcode-core-1.0.0.tgz",
    "@ivritcode/unicode": "https://github.com/Richardatf/IvritCode/releases/download/canonical-packages-2026.07.20.1/ivritcode-unicode-1.0.0.tgz",
    "@qec/core": "https://github.com/Richardatf/IvritCode/releases/download/canonical-packages-2026.07.20.1/qec-core-0.1.0.tgz",
    "@qec/ivrit-compiler": "https://github.com/Richardatf/IvritCode/releases/download/canonical-packages-2026.07.20.1/qec-ivrit-compiler-0.1.0.tgz",
    "@qec/path-router": "https://github.com/Richardatf/IvritCode/releases/download/canonical-packages-2026.07.20.1/qec-path-router-0.1.0.tgz",
    "@qec/provenance": "https://github.com/Richardatf/IvritCode/releases/download/canonical-packages-2026.07.20.1/qec-provenance-0.1.0.tgz",
    "@qec/security": "https://github.com/Richardatf/IvritCode/releases/download/canonical-packages-2026.07.20.1/qec-security-0.1.0.tgz",
    "@qec/spec": "https://github.com/Richardatf/IvritCode/releases/download/canonical-packages-2026.07.20.1/qec-spec-0.1.0.tgz"
  },
  "devDependencies": {
    "@types/node": "^22.19.7",
    "ajv": "^8.20.0",
    "cross-env": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
