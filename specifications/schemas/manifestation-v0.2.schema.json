{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantumetzchaim.com/schemas/manifestation-v0.2.schema.json",
  "title": "Quantum Etz Chaim manifestation export 0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "program",
    "seed",
    "finalState",
    "finalStateHash",
    "paths",
    "gates",
    "observation",
    "output"
  ],
  "properties": {
    "schemaVersion": { "const": "qec-manifestation-0.2" },
    "program": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^[א-ת]+$"
    },
    "seed": { "type": "integer", "minimum": 0, "maximum": 21 },
    "finalState": { "$ref": "#/$defs/state" },
    "finalStateHash": { "$ref": "#/$defs/hash" },
    "paths": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1024,
      "items": { "$ref": "#/$defs/path" }
    },
    "gates": {
      "type": "array",
      "maxItems": 1023,
      "items": { "$ref": "#/$defs/gate" }
    },
    "observation": { "$ref": "#/$defs/observation" },
    "output": { "$ref": "#/$defs/output" }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^[0-9a-f]{8}$" },
    "state": {
      "type": "array",
      "minItems": 23,
      "maxItems": 23,
      "items": { "type": "integer", "minimum": 0, "maximum": 21 }
    },
    "path": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "letter", "source", "destination", "services"],
      "properties": {
        "step": { "type": "integer", "minimum": 1 },
        "letter": { "type": "string", "pattern": "^[א-ת]$" },
        "source": { "type": "string", "minLength": 1 },
        "destination": { "type": "string", "minLength": 1 },
        "services": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "composition", "registerChanges", "coherenceDelta"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "composition": {
          "enum": ["continuation", "crossing", "reinforcement"]
        },
        "registerChanges": { "type": "integer", "minimum": 0, "maximum": 23 },
        "coherenceDelta": { "type": "number", "minimum": -1, "maximum": 1 }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selectedProjection", "stateHash", "snapshot"],
      "properties": {
        "selectedProjection": { "type": "string", "minLength": 1 },
        "stateHash": { "$ref": "#/$defs/hash" },
        "snapshot": { "$ref": "#/$defs/state" }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registerString",
        "base22Registers",
        "pathSignature",
        "checksum"
      ],
      "properties": {
        "registerString": {
          "type": "string",
          "minLength": 22,
          "maxLength": 22
        },
        "base22Registers": { "type": "string", "minLength": 1 },
        "pathSignature": { "type": "string", "minLength": 1 },
        "checksum": { "$ref": "#/$defs/hash" }
      }
    }
  }
}
