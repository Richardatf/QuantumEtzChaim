{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantumetzchaim.com/schemas/observation-v0.3.schema.json",
  "title": "Quantum Etz Chaim observation 0.3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "step",
    "reason",
    "stateHash",
    "candidates",
    "selectedProjection",
    "snapshot"
  ],
  "properties": {
    "schema": { "const": "qec-observation-0.3" },
    "step": { "type": "integer", "minimum": 0 },
    "reason": { "enum": ["program-end", "checkpoint", "explicit"] },
    "stateHash": { "$ref": "#/$defs/hash" },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/candidate" }
    },
    "selectedProjection": { "type": "string", "minLength": 1 },
    "snapshot": {
      "type": "array",
      "minItems": 23,
      "maxItems": 23,
      "items": { "type": "integer", "minimum": 0, "maximum": 21 }
    }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^[0-9a-f]{8,64}$" },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "stateHash",
        "focusLetter",
        "confidence",
        "rationale"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "stateHash": { "$ref": "#/$defs/hash" },
        "focusLetter": { "type": "string", "pattern": "^[א-ת]$" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "rationale": { "type": "string", "minLength": 1 }
      }
    }
  }
}
